{
  "name": "uncle-sams-cart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "serve": "npx serve@latest out",
    "lint": "eslint",
    "ingest:sam": "python3 scripts/ingest-sam.py",
    "build:weird": "python3 scripts/build-weird-items.py",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:d1:schema": "wrangler d1 execute uncle-sams-cart-events --remote --file workers/schema.sql"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.86.0"
  }
}
